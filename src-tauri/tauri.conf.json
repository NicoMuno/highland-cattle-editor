{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Farm Webeditor",
  "version": "0.1.0",
  "identifier": "com.highland-cattle-editor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Farm Webeditor",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "dependencies/binaries/bun"
    ],
    "resources": [
      "dependencies/resources/mingit/**/*"
    ]
  }
}